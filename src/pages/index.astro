---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 flex items-center justify-center px-4">
		<div class="max-w-4xl mx-auto text-center">
			<h1 class="text-6xl md:text-8xl font-bold text-white mb-6 bg-gradient-to-r from-blue-400 via-purple-500 to-pink-500 bg-clip-text text-transparent">
				ASTRA
			</h1>
			<p class="text-xl md:text-2xl text-gray-300 mb-8">
				The ultimate Discord Bot for your server
			</p>
			<p class="text-lg text-gray-400 mb-12 max-w-2xl mx-auto">
				ASTRA brings powerful features to enhance your Discord experience. From moderation to entertainment, manage your server like never before.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
				<a href="#" class="bg-gradient-to-r from-blue-500 to-purple-600 hover:from-blue-600 hover:to-purple-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-300 transform hover:scale-105">
					Add to Discord
				</a>
				<a href="#" class="border-2 border-purple-500 text-purple-400 hover:bg-purple-500 hover:text-white font-semibold py-3 px-8 rounded-lg transition duration-300">
					Learn More
				</a>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
				<div class="bg-slate-800/50 p-6 rounded-lg backdrop-blur-sm">
					<h3 class="text-xl font-semibold text-white mb-2">Moderation</h3>
					<p class="text-gray-400">Keep your server safe with advanced moderation tools.</p>
				</div>
				<div class="bg-slate-800/50 p-6 rounded-lg backdrop-blur-sm">
					<h3 class="text-xl font-semibold text-white mb-2">Entertainment</h3>
					<p class="text-gray-400">Fun games and commands to engage your community.</p>
				</div>
				<div class="bg-slate-800/50 p-6 rounded-lg backdrop-blur-sm">
					<h3 class="text-xl font-semibold text-white mb-2">Customization</h3>
					<p class="text-gray-400">Tailor ASTRA to fit your server's unique needs.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
